# ── Kisski API ───────────────────────────────────────────────
# Same key works for all endpoints
KISSKI_API_KEY=your-api-key-here

# LLM + embeddings base URL
KISSKI_BASE_URL=https://chat-ai.academiccloud.de/v1

# Voice to Text uses a different base URL (same key)
KISSKI_VOICE_BASE_URL=https://saia.gwdg.de/v1

# ── Models ───────────────────────────────────────────────────
# LLM for RAG evaluation (structured STOP feedback)
KISSKI_LLM_MODEL=meta-llama-3.1-8b-instruct

# Optional judge model used by benchmarking scripts
KISSKI_JUDGE_MODEL=gpt-oss-120b

# Embeddings — multilingual handles German + English natively
KISSKI_EMBEDDING_MODEL=multilingual-e5-large-instruct

# Transcription
KISSKI_VOICE_MODEL=whisper-large-v2

# ── Paths ────────────────────────────────────────────────────
KNOWLEDGE_BASE_DIR=knowledge_base/raw
VECTOR_DB_DIR=knowledge_base/processed
REGISTRY_PATH=knowledge_base/registry.json

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Comma-separated production frontend origins, e.g.
# CORS_ORIGINS=https://examiner-coach.example.org
CORS_ORIGINS=
